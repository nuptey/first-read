# Copy to .env.local for local development.
# All three variables are required for the app to start.

# Anthropic API key. Backend only — never exposed to the client.
ANTHROPIC_API_KEY=sk-ant-...

# Shared password gating access to the portal. Anyone with the deployed URL
# must enter this once.
APP_PASSWORD=change-me

# Server-side secret used to sign the auth cookie. Set to a long random string
# (e.g. `openssl rand -hex 32`). Rotating this value invalidates existing sessions.
APP_SECRET=change-me-to-a-long-random-string

# Optional. Defaults to claude-sonnet-4-6.
# MODEL=claude-sonnet-4-6
